# ============================================
# Aikyam Multi-Agent SDLC Pipeline
# Environment Configuration
# ============================================

# ── Application ──
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# ── LLM Providers ──
# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro

# OpenAI (optional)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# vLLM / Local (DGX Spark - Qwen 2.5 72B)
VLLM_BASE_URL=https://api-32b.aikyamarea51.in/v1
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct-AWQ
VLLM_API_KEY=not-needed

# Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b

# Groq (optional)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile

# Default LLM provider per agent (options: gemini, openai, vllm, ollama, groq)
DEFAULT_LLM_PROVIDER=gemini
REQUIREMENTS_AGENT_LLM=gemini
DEVELOPER_AGENT_LLM=vllm
CODE_REVIEW_AGENT_LLM=gemini
QA_AGENT_LLM=vllm
SECURITY_AGENT_LLM=gemini
DEPLOYMENT_AGENT_LLM=vllm
DOCUMENTATION_AGENT_LLM=vllm

# ── Slack ──
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_CHANNEL_ID=C0123456789
SLACK_SIGNING_SECRET=your-signing-secret

# ── Jira ──
JIRA_URL=https://freecomerscore.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=MAT

# ── GitHub ──
GITHUB_TOKEN=ghp_your-github-token
GITHUB_ORG=aikyam
GITHUB_DEFAULT_BRANCH=main

# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/aikyam
REDIS_URL=redis://localhost:6379/0

# ── Docker ──
DOCKER_HOST=unix:///var/run/docker.sock

# ── Deployment Target ──
DEPLOY_HOST=your-vps-ip
DEPLOY_USER=deploy
DEPLOY_KEY_PATH=~/.ssh/deploy_key
